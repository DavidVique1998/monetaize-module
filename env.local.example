# Retell AI Configuration
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=your_retell_agent_id_here
RETELL_BASE_URL=https://api.retellai.com

# Twilio SIP Configuration
SIP_DOMAIN=5t4n6j0wnrl.sip.livekit.cloud

# GoHighLevel Integration
GHL_TOKEN=

# Application Configuration
NEXT_PUBLIC_APP_NAME=Monetaize Agent Panel
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# API Configuration
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_VOICE_PREVIEW=true
NEXT_PUBLIC_ENABLE_REAL_TIME_MONITORING=true

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=true

# Caching
CACHE_TTL=300
ENABLE_CACHE=true

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Cron Jobs Configuration
# Secret token para autenticar requests de cron jobs externos
# Genera un token seguro aleatorio para producción
CRON_SECRET=change-this-secret-in-production
